---
import { landingPageData } from "../data/landing-page";
import "../styles/global.css";

const {
  site,
  links,
  navigation,
  hero,
  about,
  features,
  howItWorks,
  advantages,
  team,
  cta,
  footer,
} = landingPageData;

const getButtonClass = (variant: "primary" | "secondary") =>
  variant === "primary" ? "btn-primary" : "btn-secondary";
---

<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={site.description} />
    <title>{site.title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#000000" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
  </head>
  <body>
    <div class="grid-bg"></div>

    <nav class="navbar" id="navbar">
      <div class="nav-container">
        <a href="#home" class="logo">
          <img src={site.logo.src} alt={site.logo.alt} class="logo-img" />
          <span class="logo-text">{site.logo.text}<em>{site.logo.emphasizedText}</em>{site.logo.suffixText}</span>
        </a>
        <ul class="nav-links">
          {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          <li>
            <a href={links.map} class="btn-nav">
              <i class="fas fa-map-marked-alt"></i> Explore Peta
            </a>
          </li>
        </ul>
        <button class="hamburger" id="hamburgerBtn" type="button" aria-label="Buka menu" aria-controls="mobileMenu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" id="mobileMenu">
      {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={links.map}><i class="fas fa-map"></i> Explore Peta</a>
    </div>

    <main>
      <section class="hero" id="home">
        <div class="container">
          <div class="hero-inner">
            <div>
              <div class="hero-eyebrow"><i class={hero.eyebrowIcon}></i> {hero.eyebrow}</div>
              <h1 class="hero-title">
                {hero.title.firstLine}<br />{hero.title.secondLineStart} <span class="grad">{hero.title.highlightedText}</span><br />{hero.title.thirdLine}
              </h1>
              <p class="hero-desc">{hero.description}</p>
              <div class="hero-buttons">
                {hero.actions.map((action) => (
                  <a href={action.href} class={getButtonClass(action.variant)}>
                    <i class={action.icon}></i> {action.label}
                  </a>
                ))}
              </div>
            </div>
            <div class="hero-image">
              <img src={hero.image.src} alt={hero.image.alt} />
              <div class="hero-metrics" aria-label="Platform highlights">
                {hero.highlights.map((item) => (
                  <div class="hero-metric">
                    <strong>{item.value}</strong>
                    <span>{item.label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="about" id="about">
        <div class="container">
          <div class="about-inner">
            <div class="reveal-left">
              <div class="problem-card">
                {about.cards.map((card, index) => (
                  <div class:list={{ "problem-block": index > 0 }}>
                    <div class={`problem-tag ${card.tagClass}`}><i class={card.icon}></i> {card.tag}</div>
                    <h4>{card.title}</h4>
                    <p>{card.description}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class="reveal-right">
              <span class="section-label"><i class={about.labelIcon}></i> {about.label}</span>
              <h2 class="section-title">{about.title}</h2>
              <p class="section-desc">{about.description}</p>
              <div class="stats-row stagger">
                {about.stats.map((stat) => (
                  <div class="stat-item">
                    <span class="stat-num" data-target={stat.target}>{stat.target ? "0" : stat.value}</span>
                    <div><i class={stat.icon}></i> {stat.label}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="features" id="features">
        <div class="container">
          <div class="reveal text-center">
            <span class="section-label"><i class={features.labelIcon}></i> {features.label}</span>
            <h2 class="section-title">{features.title}</h2>
          </div>
          <div class="features-grid stagger">
            {features.items.map((feature) => (
              <div class="feat-card">
                <div class="feat-icon"><i class={feature.icon}></i></div>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="how-it-works" id="how">
        <div class="container">
          <div class="reveal text-center">
            <span class="section-label"><i class={howItWorks.labelIcon}></i> {howItWorks.label}</span>
            <h2 class="section-title">{howItWorks.title}</h2>
          </div>
          <div class="steps-track stagger">
            {howItWorks.steps.map((step, index) => (
              <div class="step">
                <div class="step-num">{index + 1}</div>
                <h4>{step.title}</h4>
                <p>{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="advantages" id="advantages">
        <div class="container">
          <div class="adv-inner">
            <div><img src={advantages.image.src} alt={advantages.image.alt} class="adv-image" /></div>
            <div>
              <span class="section-label"><i class={advantages.labelIcon}></i> {advantages.label}</span>
              <h2 class="section-title">{advantages.title}</h2>
              <div class="adv-list">
                {advantages.items.map((item) => (
                  <div class="adv-item">
                    <div class="adv-icon"><i class={item.icon}></i></div>
                    <div>
                      <h4>{item.title}</h4>
                      <p>{item.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="team" id="team">
        <div class="container">
          <div class="reveal text-center">
            <span class="section-label"><i class={team.labelIcon}></i> {team.label}</span>
            <h2 class="section-title">{team.title}</h2>
          </div>
          <div class="team-grid stagger">
            {team.members.map((member) => (
              <div class="team-card">
                <div class="team-photo-wrap"><img src={member.photo} class="team-photo" alt={member.name} /></div>
                <div class="team-body">
                  <div class="team-name">{member.name}</div>
                  <div class="team-role">{member.role}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="cta">
        <div class="container">
          <div class="cta-box reveal-scale reveal">
            <span class="section-label"><i class={cta.labelIcon}></i> {cta.label}</span>
            <h2 class="section-title">{cta.title}</h2>
            <p class="section-desc cta-desc">{cta.description}</p>
            <div class="cta-buttons">
              {cta.actions.map((action) => (
                <a href={action.href} class={getButtonClass(action.variant)}>
                  <i class={action.icon}></i> {action.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <footer>
        <div class="container">
          <div class="footer-grid">
            <div class="footer-brand">
              <div class="footer-logo-wrapper">
                <span class="footer-logo-text">
                  {site.logo.text}<em>{site.logo.emphasizedText}</em>{site.logo.suffixText}
                </span>
              </div>
              <p>{footer.description}</p>
              <div class="social-links">
                {footer.socialLinks.map((link) => (
                  <a href={link.href} class="social-link" aria-label={link.label}><i class={link.icon}></i></a>
                ))}
              </div>
            </div>
            {footer.columns.map((column) => (
              <div class="footer-col">
                <h5>{column.title}</h5>
                <ul>
                  {column.links.map((link) => (
                    <li>
                      <a href={link.href}>
                        {"icon" in link && link.icon && <i class={link.icon}></i>} {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <div class="footer-bottom">
            <span>{footer.copyright}</span>
            <span class="footer-tag"></span>
          </div>
        </div>
      </footer>

      <a href="#home" class="back-to-top" id="backToTop" aria-label="Kembali ke atas">
        <i class="fas fa-arrow-up"></i>
      </a>
    </main>
    <script>
      import "../scripts/main.js";
    </script>
  </body>
</html>
